# Copy to mobile/.env (gitignored) and fill in values.
# Android emulator: use http://10.0.2.2:3000 for a local backend, or production URL below.

API_BASE_URL=https://www.networxradio.com
# Direct Nest/Railway host for large multipart uploads (avoids Vercel 413).
# API_DIRECT_URL=https://backend-production-17cc.up.railway.app
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe publishable key (pk_test_… for test mode, pk_live_… for production).
# Same value as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY on web/Vercel.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
