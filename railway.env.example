# Railway environment variables template
# Use with Railway MCP set-variables or paste into Railway Dashboard.
# Replace placeholder values; do not commit real secrets.
#
# Backend service – copy these keys; set values in Railway (Dashboard or MCP).
# Format for MCP set-variables: variables = ["KEY=value", "KEY2=value2", ...]

NODE_ENV=production
PORT=3000
# Web app is on Vercel at networxradio.com
WEB_URL=https://networxradio.com
CORS_ORIGIN=https://networxradio.com,https://www.networxradio.com,https://your-backend.up.railway.app

# Firebase (set in Dashboard if value contains newlines)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY set in Dashboard (multi-line)

# Supabase
SUPABASE_URL=https://tgjydsqeatvcerzpdqup.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CREATOR_NETWORK_PRICE_ID=price_xxx

# Redis (e.g. Railway Redis plugin or Upstash URL)
REDIS_URL=redis://default:xxx@xxx.railway.app:port

# Optional
SENTRY_DSN=
ADMIN_EMAILS=
THRESHOLD_ENTER_PAID=5
THRESHOLD_EXIT_PAID=3
CHECKPOINT_INTERVAL=5

# --- Web service (if deployed separately) ---
# BACKEND_URL=https://your-backend.up.railway.app
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
# NEXT_PUBLIC_FIREBASE_* = (same as web/.env.local.example)
# NEXT_PUBLIC_SUPABASE_* = (same as web/.env.local.example)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=...
# NEXT_PUBLIC_WEB_URL=https://networxradio.com
