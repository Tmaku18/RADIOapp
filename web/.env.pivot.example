# Pivot branch environment (copy to web/.env.local)

# --- Strangler routing ---
STRANGLER_ENABLED=true
# Comma-separated modules handled by Next.js (others proxy to legacy NestJS)
STRANGLER_LOCAL_MODULES=health,auth,users,payments
# Set true when all modules ported:
# STRANGLER_LOCAL_ALL=true

# Legacy NestJS (Railway) — required until cutover completes
BACKEND_URL=https://your-backend.railway.app
NEXT_PUBLIC_API_URL=https://www.networxradio.com/api

# --- Supabase (Auth migration) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_AUTH_PRIMARY=firebase
AUTH_FIREBASE_FALLBACK=true

# Spotify / YouTube OAuth (Supabase Auth providers)
# Configure in Supabase dashboard; optional env for client hints:
NEXT_PUBLIC_SPOTIFY_OAUTH_ENABLED=true
NEXT_PUBLIC_YOUTUBE_OAUTH_ENABLED=true

# --- Monolith domain absorption ---
MONOLITH_ADMIN_ENABLED=false
MONOLITH_PRO_ENABLED=false

# --- Radio worker ---
REDIS_URL=redis://localhost:6379
RADIO_WORKER_PORT=3099
RADIO_WORKER_URL=http://localhost:3099

# --- Payments webhook ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENTS_WEBHOOK_DELEGATE_LEGACY=true

# --- Firebase (rollback / dual-auth) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
