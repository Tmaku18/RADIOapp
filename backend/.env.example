# --- FIREBASE CONFIGURATION ---
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"

# --- SUPABASE CONFIGURATION ---
# Get from Supabase Dashboard > Project Settings > API (service_role key is secret, not in MCP)
# Project URL from MCP: https://tgjydsqeatvcerzpdqup.supabase.co
SUPABASE_URL=https://tgjydsqeatvcerzpdqup.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# --- STRIPE CONFIGURATION ---
# Get these from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Creator Network subscription (Stripe Price ID). Created via Stripe MCP; use test price in test mode.
STRIPE_CREATOR_NETWORK_PRICE_ID=price_1Sz1dTJ9W2XQKTIbF7OxVyKy

# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=development

# Comma-separated list of emails that get admin role on first login (e.g. admin@yourapp.com,owner@yourapp.com)
# Leave empty to disable auto-admin.
ADMIN_EMAILS=

# Web App URL (for Stripe Checkout redirects). On Railway, set to your deployed web URL.
WEB_URL=http://localhost:3001

# --- GOOGLE PLAY BILLING (Android) ---
# Android package/application ID used in Google Play Console.
GOOGLE_PLAY_PACKAGE_NAME=com.radioapp.radio_app
# Service account JSON (single-line JSON string) with Android Publisher API access.
# You can reuse Firebase service account credentials only if the service account has
# Play Console permissions for this app.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# Product catalog mapping for server-side reconciliation and entitlement grants.
# Use this to map product IDs to granted value.
# For song plays, amount must match dynamic backend pricing ($1/minute per play)
# for the purchased song duration.
#
# Example:
# {
#   "nwx_credits_10": {"type":"credits","amountCents":999,"credits":10},
#   "nwx_credits_25": {"type":"credits","amountCents":1999,"credits":25},
#   "nwx_credits_50": {"type":"credits","amountCents":3499,"credits":50},
#   "nwx_credits_100": {"type":"credits","amountCents":5999,"credits":100},
#   "nwx_song_plays_5_1500": {"type":"song_plays","amountCents":1500,"plays":5},
#   "nwx_song_plays_10_3000": {"type":"song_plays","amountCents":3000,"plays":10}
# }
GOOGLE_PLAY_PRODUCT_CATALOG_JSON=

# --- APPLE IN-APP PURCHASE (iOS) ---
# Bundle ID must match App Store Connect / Xcode.
APPLE_IAP_BUNDLE_ID=com.tmaktechnologies.networxradio
# Sandbox for TestFlight/sandbox testers; Production for App Store.
APPLE_IAP_ENVIRONMENT=Sandbox
# Numeric Apple ID of the app in App Store Connect (required for Production verification).
APPLE_APP_APPLE_ID=
# App Store Connect → Users and Access → Integrations → In-App Purchase key (.p8).
APPLE_IAP_KEY_ID=
APPLE_IAP_ISSUER_ID=
# PEM contents of the .p8 key (use \n for newlines in a single-line env value).
APPLE_IAP_PRIVATE_KEY=
# Optional: override catalog JSON merged on top of defaults in
# src/payments/iap-product-catalog.ts (credits, song_plays, tips, pro_networx_subscription).
# Prefer identical product IDs on Play and App Store.
APPLE_IAP_PRODUCT_CATALOG_JSON=
# Optional override for Apple root CA directory (defaults to backend/certs/apple).
# APPLE_IAP_ROOT_CERTS_DIR=
# ASSN V2 URL: POST /payments/app-store/notifications
# Play RTDN URL: POST /payments/google-play/rtdn
# Pro-Networx SKU: nwx_pro_networx_monthly ($9.99, intro $4.99)
# Tip SKUs: nwx_tip_199 / nwx_tip_499 / nwx_tip_999 / nwx_tip_2499

# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# --- COPYRIGHT SCREENING (ACRCloud) ---
# Uploaded songs are fingerprinted on upload; a high-confidence match against a
# commercial recording auto-rejects the song and notifies the artist.
# Create an "Audio & Video Recognition" project at https://console.acrcloud.com
# to get the host + access key/secret.
# Leave the keys empty to disable screening (uploads are marked "skipped").
ACRCLOUD_HOST=identify-us-west-2.acrcloud.com
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
# Master switch (default true). Set to false to turn screening off entirely.
COPYRIGHT_CHECK_ENABLED=true
# Minimum provider confidence (0-100) to treat a match as infringement.
COPYRIGHT_MATCH_THRESHOLD=80

# --- LYRICS CAPTIONS (ElevenLabs) ---
# When an artist supplies lyrics with an upload, the audio + text are sent to
# ElevenLabs' forced-alignment API to produce time-synced caption lines.
# When no lyrics are supplied, the audio is transcribed (Scribe speech-to-text)
# and stored as auto-generated captions the artist can review/correct.
# Get a key at https://elevenlabs.io (Developers > API Keys).
# Leave empty to disable both (plain lyrics still display, unsynced).
ELEVENLABS_API_KEY=
# Optional: speech-to-text model for auto-captions (default scribe_v1).
# ELEVENLABS_STT_MODEL_ID=scribe_v1

# --- IMAGE MODERATION (Google Cloud Vision SafeSearch) ---
# Uploaded pictures (avatars, covers, artwork, feed posts, portfolio, DM photos)
# are screened for privacy-policy violations (nudity/sexual content, graphic
# violence) before they are stored or published.
# Create an API key with the Cloud Vision API enabled at
# https://console.cloud.google.com/apis/library/vision.googleapis.com
# Leave the key empty to skip screening (a warning is logged per upload).
GOOGLE_VISION_API_KEY=
# Master switch (default true). Set to false to turn screening off entirely.
IMAGE_MODERATION_ENABLED=true

# --- ERROR TRACKING ---
# Get from Sentry Dashboard > Project Settings > Client Keys (DSN)
# Leave empty to disable error reporting
SENTRY_DSN=https://your-key@o123456.ingest.us.sentry.io/your-project-id

# --- REDIS (optional for dev; recommended for radio state, listener count, emoji aggregation) ---
# Leave unset to use redis://localhost:6379. Set when using a remote Redis or non-default port.
REDIS_URL=redis://localhost:6379

# --- RADIO CONFIGURATION ---
# Hysteresis thresholds for switching between free rotation and paid playlist
# Uses different thresholds for entering vs exiting to prevent rapid oscillation
# Enter paid mode when listeners >= THRESHOLD_ENTER_PAID
THRESHOLD_ENTER_PAID=5
# Exit paid mode (return to free) when listeners <= THRESHOLD_EXIT_PAID
THRESHOLD_EXIT_PAID=3
# Checkpoint frequency: save position to database every N songs
CHECKPOINT_INTERVAL=5
